# harvester 路径；不配置时默认使用同级 ../harvester-THS
HARVESTER_ROOT=

# 飞书普通表格配置；线上只读，本项目只同步到本地 SQLite
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WIKI_TOKEN=
FEISHU_SPREADSHEET_TOKEN=
FEISHU_SHEET_DOUYIN=
FEISHU_SHEET_XHS=
FEISHU_SHEET_BILIBILI=
FEISHU_SHEET_DOUYIN_HISTORY=
FEISHU_SHEET_XHS_HISTORY=
FEISHU_SHEET_BILIBILI_HISTORY=
FEISHU_OPEN_BASE_URL=https://open.feishu.cn

# MiniMax 高价值内容多模态复盘
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_FETCH_TIMEOUT_SEC=90

# 可选：外部 XHS-Downloader sidecar，配置后用于 /xhs/detail 详情补齐
XHS_DOWNLOADER_BASE_URL=
